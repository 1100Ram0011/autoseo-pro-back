# ===================================================
# AutoSEO Pro — Environment Variables
# Copy this to .env and fill in your values
# ===================================================

# --- APP SETTINGS ---
PORT=4000
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"
BACKEND_URL="http://localhost:4000"
LOG_LEVEL="info"

# --- DATABASE ---
DATABASE_URL="file:./dev.db"
# For PostgreSQL (production):
# DATABASE_URL="postgresql://user:password@localhost:5432/autoseo_pro"

# --- CORE AI API ---
# Get your free API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# --- GOOGLE SEO & ANALYTICS APIs ---
PAGESPEED_API_KEY="your_pagespeed_api_key_here"
GOOGLE_APPLICATION_CREDENTIALS="./service-account.json"
GOOGLE_ANALYTICS_MEASUREMENT_ID=""

# --- GOOGLE OAUTH (Login with Google) ---
GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"
GOOGLE_CALLBACK_URL="http://localhost:3000/api/auth/callback/google"

# --- TRACKING & GEOLOCATION ---
IP_GEOLOCATION_API_KEY=""
MICROSOFT_CLARITY_ID=""
CLARITY_API_TOKEN=""

# --- BLOG & SOCIAL AUTO-POSTING ---
MEDIUM_API_KEY=""
DEVTO_API_KEY=""
HASHNODE_API_KEY=""
LINKEDIN_API_KEY=""
REDDIT_API_KEY=""
TWITTER_API_KEY=""

# --- PAYMENTS (Stripe) ---
STRIPE_SECRET_KEY=""
STRIPE_PRICE_PRO=""

# --- REDIS ---
REDIS_URL="redis://localhost:6379"

# --- WhatsApp Engine API ---
WHATSAPP_ENGINE_URL="http://localhost:3001"
WHATSAPP_ENGINE_KEY=""

# --- AWS S3 (Needed for WhatsApp Validation Excel Uploads) ---
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_BUCKET_NAME=""

# --- LEADS & SCRAPING ---
GOOGLE_MAPS_API_KEY=""
ROCKETREACH_API_KEY=""
APIFY_API_TOKEN=""

# --- Firecrawl Fallback Settings ---
FIRECRAWL_API_KEY=""
#PROXY_URL=http://user:pass@proxy-ip:port

# --- WORDPRESS AUTO-POSTING ---
#WP_API_URL=https://your-site.com/wp-json/wp/v2
#WP_USER=your_wp_username
#WP_APP_PASSWORD=your_wp_app_password
